{
    "name": "ARP Protocol",
    "header": {
        "0_16": {
            "description": "Hardware Type (HTYPE)"
        },
        "16_16": {
            "description": "Protocol Type (PTYPE)"
        },
        "32_8": {
            "description": "Hardware Address Length"
        },
        "40_8": {
            "description": "Protocol Address Length"
        },
        "48_16": {
            "description": "Operation (1=request, 2=reply)"
        },
        "64_48": {
            "description": "Sender Hardware Address (MAC)"
        },
        "112_32": {
            "description": "Sender Protocol Address (IP)"
        },
        "144_48": {
            "description": "Target Hardware Address (MAC)"
        },
        "192_32": {
            "description": "Target Protocol Address (IP)"
        }
    }
}
