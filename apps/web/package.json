{
    "name": "@repo/web",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "NODE_ENV=development tsx watch src/server.ts",
        "build:client": "vite build",
        "build:server": "node esbuild.config.mjs",
        "build:standalone": "node esbuild.standalone.mjs",
        "build": "pnpm run build:client && pnpm run build:server",
        "package": "pnpm run build:client && pnpm run build:standalone && ./scripts/package-server.sh",
        "start": "NODE_ENV=production node dist/server/server.js"
    },
    "dependencies": {
        "@repo/core-node": "workspace:*",
        "@repo/front": "workspace:*",
        "@repo/utils": "workspace:*",
        "express": "^5.2.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.4",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "esbuild": "^0.28.0",
        "postcss": "^8.5.12",
        "tailwindcss": "^4.2.4",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.10"
    }
}
