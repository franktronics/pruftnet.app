{
    "version": "0.1.1",
    "name": "pruftnet",
    "private": false,
    "type": "module",
    "scripts": {
        "dev:web": "node setup.js --web && pnpm -F @repo/web run dev",
        "dev:desktop": "node setup.js --desktop && node setup-dev.js && pnpm -F @repo/desktop run dev",
        "build:core": "pnpm -F @repo/core-cpp run build",
        "build:desktop": "pnpm build:core && pnpm -F @repo/desktop run rebuild && pnpm -F @repo/desktop run make",
        "build:server": "pnpm build:core && pnpm -F @repo/web run package",
        "setup": "node setup.js",
        "db:generate": "pnpm --filter @repo/core-node run db:generate",
        "db:migrate": "pnpm --filter @repo/core-node run db:migrate",
        "format": "prettier --write .",
        "clean": "node clean.js",
        "setup:caps": "sudo setcap cap_net_raw,cap_net_admin=eip $(which node)",
        "check:caps": "getcap $(which node)",
        "typecheck": "pnpm -r --filter=@repo/core-node --filter=@repo/front --filter=@repo/ui --filter=@repo/utils run type-check"
    },
    "packageManager": "pnpm@10.28.1",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/engines",
            "@swc/core",
            "@tailwindcss/oxide",
            "better-sqlite3",
            "electron",
            "electron-winstaller",
            "esbuild",
            "prisma",
            "unrs-resolver"
        ],
        "overrides": {
            "tmp@<=0.2.3": ">=0.2.4",
            "tar@<=7.5.2": ">=7.5.3"
        }
    }
}
