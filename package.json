{
    "name": "pruftnet",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:web": "pnpm -F @repo/web run dev",
        "dev:desktop": "pnpm -F @repo/desktop run dev",
        "build:core": "pnpm -F @repo/core-cpp run build",
        "test:build": "pnpm -F @repo/core-cpp run test:build",
        "test:run": "pnpm -F @repo/core-cpp run test:run",
        "format": "prettier --write .",
        "clean": "node clean.js",
        "setup:caps": "sudo setcap cap_net_raw,cap_net_admin=eip $(which node)",
        "check:caps": "getcap $(which node)"
    },
    "packageManager": "pnpm@10.25.0",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.7.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@swc/core",
            "@tailwindcss/oxide",
            "electron",
            "electron-winstaller",
            "esbuild",
            "unrs-resolver"
        ]
    }
}
