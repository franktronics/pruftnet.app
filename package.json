{
    "name": "pruftnet",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:web": "turbo run dev:web --filter=@repo/web",
        "dev:desktop": "turbo run dev:desktop --filter=@repo/web",
        "build:web": "turbo run build:web --filter=@repo/web",
        "build:desktop": "turbo run build:desktop --filter=@repo/web",
        "format": "prettier --write .",
        "clean": "node clean.js",
        "install-electron": "node apps/electron/node_modules/electron/install.js"
    },
    "packageManager": "pnpm@10.16.1",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^24.3.3",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "turbo": "^2.5.6"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller"
        ]
    }
}
