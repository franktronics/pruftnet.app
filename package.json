{
    "name": "pruftnet",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:web": "pnpm -F @repo/web run dev",
        "dev:desktop": "pnpm -F @repo/desktop run dev",
        "build:core": "pnpm -F @repo/core run build",
        "format": "prettier --write .",
        "clean": "node clean.js"
    },
    "packageManager": "pnpm@10.18.0",
