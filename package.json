{
    "name": "pruftnet",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:web": "turbo run dev --filter=@repo/web",
        "dev:desktop": "turbo run dev --filter=@repo/desktop",
        "format": "prettier --write .",
        "clean": "node clean.js"
    },
    "packageManager": "pnpm@10.17.1",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^24.3.3",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "turbo": "^2.5.8"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller"
        ]
    }
}
